# ---- n8n (volume de mensagens + base do custo) ----
N8N_BASE_URL=https://revopspsa.app.n8n.cloud
N8N_WORKFLOW_ID=ABZUMMhJizuP9mDv
N8N_API_KEY=cole_a_sua_key_aqui

# ---- HubSpot (escalacoes + topicos + conversas unicas) ----
# Crie um Private App em Settings > Integrations > Private Apps
# Scope minimo: crm.objects.contacts.read
HUBSPOT_TOKEN=pat-na1-xxxxxxxx

# ---- Custo do LLM (estimativa v1) ----
# Modelo usado pelo no AI Agent do Max. Ex: gpt-4o-mini, gpt-4o, claude-sonnet-4
LLM_MODEL=gpt-4o-mini
# Media estimada de tokens por mensagem (entrada+saida). Ajuste quando souber o real.
LLM_AVG_TOKENS_IN=1200
LLM_AVG_TOKENS_OUT=350
